# =============================================================================
# Dashboard Restaurante — Variables de Entorno
# Copia este archivo a server/.env y completa los valores
# =============================================================================

# ── BASE DE DATOS (REQUERIDO) ─────────────────────────────────────────────────
# Neon: postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/dbname?sslmode=require
# Supabase: postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres
# Railway: se inyecta automáticamente como DATABASE_URL
DATABASE_URL=postgresql://postgres:CAMBIAR@localhost:5432/dashboard_restaurante

# ── AUTENTICACIÓN (REQUERIDO) ─────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CAMBIAR_POR_CLAVE_LARGA_Y_ALEATORIA_MINIMO_64_CHARS
ADMIN_CODE=codigo_para_registrar_primer_admin

# ── SERVIDOR ──────────────────────────────────────────────────────────────────
PORT=9000
NODE_ENV=production
LOG_LEVEL=info

# URL del frontend (para CORS en producción)
# Vercel: https://tu-app.vercel.app
FRONTEND_URL=https://tu-frontend.vercel.app

# ── CLOUDFLARE R2 (logos de restaurantes) ────────────────────────────────────
# Panel: dash.cloudflare.com -> R2 -> bucket -> Manage R2 API tokens
R2_ACCOUNT_ID=tu_account_id
R2_ACCESS_KEY_ID=tu_access_key_id
R2_SECRET_ACCESS_KEY=tu_secret_access_key
R2_BUCKET=dashboard-logos
# URL publica (activa Custom Domain en el bucket o usa el subdominio por defecto)
# Si no se configura, usa: https://pub-<ACCOUNT_ID>.r2.dev
R2_PUBLIC_URL=https://logos.tu-dominio.com

# ── REDIS (opcional -- WebSocket multi-instancia) ─────────────────────────────
# Upstash: rediss://default:password@region.upstash.io:6379
# Railway Redis: se inyecta automaticamente como REDIS_URL
# Sin Redis: el servidor funciona en modo single-instance
REDIS_URL=redis://localhost:6379

# ── EMAIL / ALERTAS STOCK BAJO (opcional) ────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=tucorreo@gmail.com
SMTP_PASS=app-password-de-gmail
SMTP_FROM=Dashboard Restaurante <tucorreo@gmail.com>
ALERT_EMAIL=admin@mirestaurante.com

# ── POSTGRESQL (solo para docker-compose local) ───────────────────────────────
POSTGRES_PASSWORD=cambiar_en_produccion
