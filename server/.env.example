# ── Base de datos ──────────────────────────────────────────────────────────────
# PostgreSQL local:
DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/dashboard_restaurante"
# PostgreSQL en Railway / Supabase / Render: pega la URL que te dan en el panel

# ── Seguridad ──────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia_esto_por_una_clave_larga_y_aleatoria_de_al_menos_64_chars"

# Código para acciones críticas (eliminar ventas, pedidos, usuarios)
ADMIN_CODE="codigo_secreto_de_admin"

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=9000
NODE_ENV=development

# URL del frontend (solo necesaria en producción para CORS)
# FRONTEND_URL=https://tu-dominio.com

# ── Redis (opcional — sin esto usa caché en memoria) ──────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Email / Alertas de stock bajo ─────────────────────────────────────────────
# Para Gmail: usa una contraseña de aplicación, no tu contraseña normal
# https://myaccount.google.com/apppasswords
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu_email@gmail.com
# SMTP_PASS=xxxx_xxxx_xxxx_xxxx
# ALERT_EMAIL=destinatario_alertas@gmail.com

# ── Supabase Storage (opcional — para logo del restaurante) ───────────────────
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...
