# ── Base de datos ──────────────────────────────────────────────────────────────
# Para queries (puede ser la URL con pooler PgBouncer en Supabase)
DATABASE_URL="postgresql://postgres:tu_password@localhost:5432/dashboard_restaurante"
# Para migraciones (conexión directa sin pooler — requerida para prisma migrate)
# Supabase: postgresql://postgres.[ref]:[pass]@db.[ref].supabase.co:5432/postgres
# Railway / local: igual que DATABASE_URL
DIRECT_URL="postgresql://postgres:tu_password@localhost:5432/dashboard_restaurante"

# ── Seguridad ──────────────────────────────────────────────────────────────────
# Genera con: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="cambia_esto_por_una_clave_larga_y_aleatoria_de_al_menos_64_chars"

# Código para acciones críticas (eliminar ventas, pedidos, usuarios)
ADMIN_CODE="codigo_secreto_de_admin"

# ── Servidor ───────────────────────────────────────────────────────────────────
PORT=9000
NODE_ENV=development

# URL del frontend (solo necesaria en producción para CORS)
# FRONTEND_URL=https://tu-dominio.com

# URL pública del backend — necesaria para que PayPal redirija al endpoint /billing/success
# y para el callback de Google OAuth (GOOGLE_CLIENT_ID/GOOGLE_CLIENT_SECRET abajo)
# En Railway la encuentras en: Settings → Networking → Public Networking
# BACKEND_URL=https://tu-app.railway.app

# ── Google OAuth ("Continuar con Google") ─────────────────────────────────────
# Panel: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI debe ser exactamente: {BACKEND_URL}/api/auth/google/callback
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ── Cloudinary (opcional — fotos de platos en Configuración → Menú) ──────────
# Panel: https://cloudinary.com/console
# CLOUDINARY_CLOUD_NAME=
# CLOUDINARY_API_KEY=
# CLOUDINARY_API_SECRET=

# ── Redis (opcional — sin esto usa caché en memoria) ──────────────────────────
# REDIS_URL=redis://localhost:6379

# ── Email / Alertas de stock bajo ─────────────────────────────────────────────
# API key de Resend — https://resend.com/api-keys (envía desde hola@mastexopos.com)
# RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
# ALERT_EMAIL=destinatario_alertas@gmail.com

# ── Supabase Storage (opcional — para logo del restaurante) ───────────────────
# SUPABASE_URL=https://xxx.supabase.co
# SUPABASE_SERVICE_KEY=eyJ...

# ── IA / Anthropic — AI Insights widget en el dashboard ───────────────────────
# Obtén tu clave en: https://console.anthropic.com → API Keys
# Sin esta clave el widget muestra insights estáticos basados en tus datos reales.
# ANTHROPIC_API_KEY=sk-ant-...

# ── PayPal ─────────────────────────────────────────────────────────────────────
# Panel: https://developer.paypal.com → My Apps & Credentials
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
# "live" para producción, "sandbox" para pruebas
PAYPAL_MODE=live
# IDs de planes de suscripción creados en el panel de PayPal
PAYPAL_PLAN_ID_PRO=
PAYPAL_PLAN_ID_BUSINESS=
# ID del webhook creado en: https://developer.paypal.com → Webhooks
PAYPAL_WEBHOOK_ID=
