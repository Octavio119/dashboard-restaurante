    { "name": "Reservas",   "description": "Reservas de mesas" },
    { "name": "Clientes",   "description": "CRM de clientes" },
    { "name": "Productos",  "description": "Catálogo de productos" },
    { "name": "Inventario",     "description": "Movimientos de stock" },
    { "name": "Caja",           "description": "Apertura y cierre de caja" },
    { "name": "Usuarios",       "description": "Gestión de usuarios y roles" },
